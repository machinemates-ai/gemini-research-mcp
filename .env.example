# Required: Google AI Studio API key
# Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-api-key-here

# Optional: Override the default model for research_web
# GEMINI_MODEL=gemini-3.1-pro-preview

# Optional: Override the model for session summaries (fast, cheap)
# GEMINI_SUMMARY_MODEL=gemini-3-flash-preview

# Optional: Override the default Deep Research agent used by research_deep.
# Accepted aliases: fast, standard, deep-research, max, deep-research-max
# Exact IDs are also accepted:
# - deep-research-preview-04-2026
# - deep-research-max-preview-04-2026
# research_deep_max always uses the Max agent.
# DEEP_RESEARCH_AGENT=deep-research-preview-04-2026

# Optional: Vertex AI project settings
